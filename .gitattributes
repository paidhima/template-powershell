# Normalize line endings
* text=auto

# Force CRLF for PowerShell source
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Force LF for config and docs
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
